# ===========================================================================
# MCP Context Server — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with MCP_ as required by pydantic-settings.
# ===========================================================================

# --- Session Storage ---
# Directory where session context files are persisted as JSON.
# Default: ~/.mcp-context-server/sessions
# MCP_SESSIONS_DIR=C:\Users\akundu\.mcp-context-server\sessions

# --- Jira Integration ---
# Your Jira Cloud or Server instance URL
# MCP_JIRA_BASE_URL=https://yourorg.atlassian.net
# MCP_JIRA_EMAIL=your.email@company.com
# MCP_JIRA_API_TOKEN=your-jira-api-token

# --- Confluence Integration ---
# Your Confluence Cloud or Server instance URL
# MCP_CONFLUENCE_BASE_URL=https://yourorg.atlassian.net/wiki
# MCP_CONFLUENCE_EMAIL=your.email@company.com
# MCP_CONFLUENCE_API_TOKEN=your-confluence-api-token

# --- Git Repositories ---
# Comma-separated list of git repo paths to make available
# MCP_GIT_DEFAULT_REPOS=["C:\\Users\\akundu\\projects\\mercury-services-commons","C:\\Users\\akundu\\projects\\other-repo"]

# --- Knowledge Base ---
# Comma-separated list of filesystem roots to search for documentation/code
# MCP_KB_ROOTS=["C:\\Users\\akundu\\projects","C:\\Users\\akundu\\OneDrive - WiseTech Global Pty Ltd\\aiengg"]

# File extensions to index (JSON array format)
# MCP_KB_FILE_EXTENSIONS=[".md",".txt",".java",".py",".xml",".json",".yaml",".yml",".properties",".gradle",".toml",".sh"]

# Maximum file size to index (in KB)
# MCP_KB_MAX_FILE_SIZE_KB=512

# --- Server ---
# MCP_SERVER_NAME=mcp-context-server
# MCP_LOG_LEVEL=INFO
